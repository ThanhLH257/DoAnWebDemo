@page
@model ConfirmEmailModel
@{
    ViewData["Title"] = "Xác nhận Email";
}

<div class="container py-5 mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                <!-- Header màu xanh lá với Icon Thành công -->
                <div class="bg-success py-4 text-center">
                    <div class="d-inline-flex align-items-center justify-content-center bg-white rounded-circle shadow" style="width: 100px; height: 100px;">
                        <i class="bi bi-patch-check-fill text-success" style="font-size: 4rem;"></i>
                    </div>
                </div>

                <div class="card-body p-5 text-center">
                    <h2 class="fw-bold text-dark mb-2">Xác nhận thành công!</h2>
                    <p class="text-muted mb-4">Chúc mừng, email của bạn đã được xác thực trên hệ thống FastLoan.</p>

                    <div class="bg-light p-4 rounded-4 mb-4 border border-light">
                        <p class="mb-0 text-secondary small lh-lg">
                            Tài khoản của bạn đã sẵn sàng. Bây giờ bạn có thể đăng nhập để trải nghiệm các gói vay ưu đãi và quản lý tài chính thông minh.
                        </p>
                    </div>

                    <a asp-page="./Login" class="btn btn-success btn-lg w-100 py-3 rounded-pill fw-bold shadow-sm text-white transition-all hover-lift">
                        <i class="bi bi-box-arrow-in-right me-2"></i> Đăng nhập ngay
                    </a>
                </div>
            </div>

            <div class="text-center mt-4">
                <p class="small text-muted">
                    Cần hỗ trợ thêm? <a href="#!" class="text-primary text-decoration-none fw-medium">Liên hệ chúng tôi</a>
                </p>
            </div>
        </div>
    </div>
</div>

<style>
    .hover-lift:hover {
        transform: translateY(-2px);
        box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.15) !important;
    }
</style>