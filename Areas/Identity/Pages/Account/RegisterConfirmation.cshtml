@page
@model RegisterConfirmationModel
@{
    ViewData["Title"] = "Xác nhận Đăng ký";
}

<div class="container py-5 mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                <!-- Header màu xanh với Icon Thư xác nhận -->
                <div class="bg-primary py-4 text-center">
                    <div class="d-inline-flex align-items-center justify-content-center bg-white rounded-circle shadow" style="width: 100px; height: 100px;">
                        <i class="bi bi-envelope-open-heart-fill text-primary" style="font-size: 3.5rem;"></i>
                    </div>
                </div>

                <div class="card-body p-5 text-center">
                    <h2 class="fw-bold text-dark mb-3">Kiểm tra hộp thư!</h2>

                    <p class="text-secondary fs-6 mb-4 lh-lg">
                        Chúng tôi vừa gửi một email chứa liên kết xác nhận tài khoản đến địa chỉ: <br />
                        <span class="badge bg-light text-primary border px-3 py-2 fs-6 mt-1 fw-bold">@Model.Email</span>
                    </p>

                    <div class="p-3 rounded-4 mb-4 text-start" style="background-color: #fff9f0; border: 1px dashed #ffcc80;">
                        <p class="small text-dark mb-0">
                            <i class="bi bi-info-circle-fill text-warning me-2"></i>
                            <strong>Mẹo nhỏ:</strong> Nếu không thấy email trong vài phút, bạn hãy kiểm tra mục <strong>Thư rác (Spam)</strong> hoặc tab Quảng cáo.
                        </p>
                    </div>

                    <div class="d-grid gap-2">
                        <a href="/" class="btn btn-primary py-3 rounded-pill fw-bold shadow-sm transition-all hover-lift">
                            <i class="bi bi-house-door me-2"></i> Quay lại Trang chủ
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .hover-lift:hover {
        transform: translateY(-2px);
        box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.15) !important;
    }
</style>