@page
@model SetPasswordModel
@{
    ViewData["Title"] = "Thiết lập mật khẩu";
    ViewData["ActivePage"] = ManageNavPages.ChangePassword;
}

<h4 class="fw-bold text-dark mb-4 text-uppercase" style="letter-spacing: 1px;">
    <i class="bi bi-shield-lock-fill text-primary me-2"></i> @ViewData["Title"]
</h4>

<partial name="_StatusMessage" for="StatusMessage" />

<div class="row">
    <div class="col-md-8 col-xl-7">
        <!-- Thông báo giải thích lý do cần thiết lập mật khẩu -->
        <div class="alert alert-info border-0 rounded-4 p-4 mb-4 shadow-sm small">
            <div class="d-flex align-items-center">
                <i class="bi bi-info-circle-fill me-3 fs-4"></i>
                <div>
                    <strong>Thông tin:</strong> Hiện tại bạn đang đăng nhập qua dịch vụ Google. Hãy thiết lập mật khẩu nội bộ để có thể đăng nhập vào FastLoan bằng địa chỉ Email bất cứ lúc nào.
                </div>
            </div>
        </div>

        <form id="set-password-form" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>

            <div class="bg-light p-4 rounded-4 mb-4 border border-white shadow-sm">
                <!-- Mật khẩu mới -->
                <div class="form-floating mb-3 shadow-sm rounded-3 overflow-hidden">
                    <input asp-for="Input.NewPassword" class="form-control border-0 bg-white" autocomplete="new-password" placeholder="Mật khẩu mới" />
                    <label asp-for="Input.NewPassword" class="text-muted small fw-bold">Mật khẩu mới</label>
                    <span asp-validation-for="Input.NewPassword" class="text-danger small px-2"></span>
                </div>

                <!-- Xác nhận mật khẩu -->
                <div class="form-floating mb-0 shadow-sm rounded-3 overflow-hidden">
                    <input asp-for="Input.ConfirmPassword" class="form-control border-0 bg-white" autocomplete="new-password" placeholder="Xác nhận mật khẩu" />
                    <label asp-for="Input.ConfirmPassword" class="text-muted small fw-bold">Xác nhận mật khẩu mới</label>
                    <span asp-validation-for="Input.ConfirmPassword" class="text-danger small px-2"></span>
                </div>
            </div>

            <button type="submit" class="btn btn-primary btn-lg w-100 py-3 rounded-pill fw-bold shadow-sm transition-all hover-lift">
                <i class="bi bi-check2-circle me-2"></i> HOÀN TẤT THIẾT LẬP
            </button>
        </form>
    </div>

    <!-- Cột mẹo bảo mật đồng bộ với trang ChangePassword -->
    <div class="col-md-4 d-none d-xl-block">
        <div class="p-4 rounded-4" style="background-color: #f0f7ff; border: 1px dashed #0d6efd;">
            <h6 class="fw-bold text-primary mb-3"><i class="bi bi-lightbulb-fill"></i> Mẹo bảo mật</h6>
            <p class="small text-secondary lh-lg mb-0">
                Một mật khẩu an toàn nên có ít nhất 6 ký tự, bao gồm cả chữ cái, chữ số và các ký tự đặc biệt để bảo vệ tài khoản vay của bạn tốt nhất.
            </p>
        </div>
    </div>
</div>

<style>
    .hover-lift:hover {
        transform: translateY(-3px);
        box-shadow: 0 10px 20px rgba(13, 110, 253, 0.15) !important;
    }

    .transition-all {
        transition: all 0.3s ease;
    }
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}