@page
@model IndexModel
@{
    ViewData["Title"] = "Hồ sơ cá nhân";
    ViewData["ActivePage"] = ManageNavPages.Index;
}

<h4 class="fw-bold text-dark mb-4 text-uppercase" style="letter-spacing: 1px;">
    <i class="bi bi-person-vcard-fill text-primary me-2"></i> @ViewData["Title"]
</h4>

<partial name="_StatusMessage" for="StatusMessage" />

<div class="row">
    <div class="col-md-8 col-xl-7">
        <form id="profile-form" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>

            <div class="bg-light p-4 rounded-4 mb-4 border border-white shadow-sm">
                <!-- Username (Read only) -->
                <div class="form-floating mb-3">
                    <input asp-for="Username" class="form-control rounded-3 border-0 bg-white" placeholder="Tên đăng nhập" disabled />
                    <label asp-for="Username" class="text-muted small fw-bold">Tên đăng nhập (Email)</label>
                </div>

                <!-- Phone Number -->
                <div class="form-floating mb-0">
                    <input asp-for="Input.PhoneNumber" class="form-control rounded-3 border-0 bg-white" placeholder="Số điện thoại" />
                    <label asp-for="Input.PhoneNumber" class="text-muted small fw-bold">Số điện thoại liên hệ</label>
                    <span asp-validation-for="Input.PhoneNumber" class="text-danger small"></span>
                </div>
            </div>

            <button id="update-profile-button" type="submit" class="btn btn-primary btn-lg w-100 py-3 rounded-pill fw-bold shadow-sm transition-all hover-lift">
                <i class="bi bi-shield-check me-2"></i> CẬP NHẬT HỒ SƠ
            </button>
        </form>
    </div>

    <!-- Cột thông tin phụ bên phải -->
    <div class="col-md-4 d-none d-xl-block">
        <div class="p-4 rounded-4" style="background-color: #f0f7ff; border: 1px dashed #0d6efd;">
            <h6 class="fw-bold text-primary mb-3"><i class="bi bi-info-square-fill"></i> Thông tin hữu ích</h6>
            <p class="small text-secondary lh-lg mb-0">
                Việc giữ cho thông tin liên hệ chính xác giúp bạn nhận được các thông báo giải ngân và nhắc nợ quan trọng từ FastLoan nhanh chóng hơn.
            </p>
        </div>
    </div>
</div>

<style>
    .hover-lift:hover {
        transform: translateY(-3px);
        box-shadow: 0 10px 20px rgba(13, 110, 253, 0.15) !important;
    }

    .transition-all {
        transition: all 0.3s ease;
    }
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}