@page
@model ExternalLoginsModel
@{
    ViewData["Title"] = "Tài khoản liên kết";
    ViewData["ActivePage"] = ManageNavPages.ExternalLogins;
}

<h4 class="fw-bold text-dark mb-4 text-uppercase" style="letter-spacing: 1px;">
    <i class="bi bi-person-plus-fill text-primary me-2"></i> @ViewData["Title"]
</h4>

<partial name="_StatusMessage" for="StatusMessage" />

<div class="row">
    <div class="col-md-10">
        @if (Model.CurrentLogins?.Count > 0)
        {
            <div class="bg-light p-4 rounded-4 mb-4 border border-white shadow-sm">
                <h6 class="fw-bold text-muted mb-3 small">TÀI KHOẢN ĐANG LIÊN KẾT</h6>
                <div class="table-responsive">
                    <table class="table table-borderless align-middle mb-0">
                        <tbody>
                            @foreach (var login in Model.CurrentLogins)
                            {
                                <tr>
                                    <td class="ps-0 py-3">
                                        <div class="d-flex align-items-center">
                                            @if (login.ProviderDisplayName == "Google")
                                            {
                                                <img src="https://upload.wikimedia.org/wikipedia/commons/c/c1/Google_%22G%22_logo.svg" alt="Google" style="width: 20px; height: 20px;" class="me-3">
                                            }
                                            <span class="fw-bold text-dark">@login.ProviderDisplayName</span>
                                        </div>
                                    </td>
                                    <td class="text-end pe-0 py-3">
                                        @if (Model.ShowRemoveButton)
                                        {
                                            <form id="@($"remove-login-{login.LoginProvider}")" asp-page-handler="RemoveLogin" method="post">
                                                <div>
                                                    <input asp-for="@login.LoginProvider" name="LoginProvider" type="hidden" />
                                                    <input asp-for="@login.ProviderKey" name="ProviderKey" type="hidden" />
                                                    <button type="submit" class="btn btn-outline-danger btn-sm rounded-pill px-3 fw-bold" title="Gỡ liên kết @login.ProviderDisplayName">
                                                        <i class="bi bi-x-circle me-1"></i> Gỡ bỏ
                                                    </button>
                                                </div>
                                            </form>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary rounded-pill">Mặc định</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }

        @if (Model.OtherLogins?.Count > 0)
        {
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                <div class="card-body p-4 p-md-5 text-center">
                    <h5 class="fw-bold mb-3">Thêm dịch vụ đăng nhập khác</h5>
                    <p class="text-muted mb-4">Kết nối thêm các tài khoản xã hội để đăng nhập vào FastLoan nhanh hơn.</p>

                    <form id="link-login-form" asp-page-handler="LinkLogin" method="post" class="form-horizontal">
                        <div id="social-login-list">
                            <p>
                                @foreach (var provider in Model.OtherLogins)
                                {
                                    <button id="@($"link-login-button-{provider.Name}")" type="submit" class="btn btn-outline-dark btn-lg px-5 py-3 rounded-pill fw-bold shadow-sm transition-all hover-lift" name="provider" value="@provider.Name" title="Đăng nhập bằng @provider.DisplayName">
                                        @if (provider.DisplayName == "Google")
                                        {
                                            <img src="https://upload.wikimedia.org/wikipedia/commons/c/c1/Google_%22G%22_logo.svg" alt="Google" style="width: 20px; height: 20px;" class="me-2 mb-1">
                                        }
                                        Tiếp tục với @provider.DisplayName
                                    </button>
                                }
                            </p>
                        </div>
                    </form>
                </div>
            </div>
        }
    </div>
</div>

<style>
    .hover-lift:hover {
        transform: translateY(-3px);
        box-shadow: 0 10px 20px rgba(0, 0, 0, 0.08) !important;
    }
</style>