@page
@model EmailModel
@{
    ViewData["Title"] = "Quản lý Email";
    ViewData["ActivePage"] = ManageNavPages.Email;
}

<h4 class="fw-bold text-dark mb-4 text-uppercase" style="letter-spacing: 1px;">
    <i class="bi bi-envelope-at-fill text-primary me-2"></i> @ViewData["Title"]
</h4>

<partial name="_StatusMessage" for="StatusMessage" />

<div class="row">
    <div class="col-md-8 col-xl-7">
        <form id="email-form" method="post">
            <div asp-validation-summary="All" class="text-danger mb-3" role="alert"></div>

            <div class="bg-light p-4 rounded-4 mb-4 border border-white shadow-sm">
                <!-- Email hiện tại -->
                <div class="mb-4">
                    <label class="form-label text-muted small fw-bold mb-2">Email hiện tại</label>
                    <div class="input-group">
                        <input asp-for="Email" class="form-control rounded-3 border-0 bg-white py-2" placeholder="Email hiện tại" disabled />
                        <span class="input-group-text bg-white border-0 text-success rounded-3 ms-1">
                            <i class="bi bi-check-circle-fill"></i>
                        </span>
                    </div>
                </div>

                <!-- Nhập Email mới -->
                <div class="form-floating mb-0">
                    <input asp-for="Input.NewEmail" class="form-control rounded-3 border-0 bg-white" autocomplete="email" aria-required="true" placeholder="Email mới" />
                    <label asp-for="Input.NewEmail" class="text-muted small fw-bold">Địa chỉ Email mới</label>
                    <span asp-validation-for="Input.NewEmail" class="text-danger small"></span>
                </div>
            </div>

            <button id="change-email-button" type="submit" asp-page-handler="ChangeEmail" class="btn btn-primary btn-lg w-100 py-3 rounded-pill fw-bold shadow-sm transition-all hover-lift">
                <i class="bi bi-send-check-fill me-2"></i> XÁC NHẬN THAY ĐỔI
            </button>
        </form>
    </div>

    <div class="col-md-4 d-none d-xl-block">
        <div class="p-4 rounded-4" style="background-color: #f0f7ff; border: 1px dashed #0d6efd;">
            <h6 class="fw-bold text-primary mb-3"><i class="bi bi-info-circle-fill"></i> Lưu ý</h6>
            <p class="small text-secondary lh-lg mb-0">
                Sau khi thay đổi, hệ thống sẽ gửi một liên kết xác thực đến Email mới. Bạn cần nhấn vào liên kết đó để hoàn tất quá trình cập nhật.
            </p>
        </div>
    </div>
</div>

<style>
    .hover-lift:hover {
        transform: translateY(-3px);
        box-shadow: 0 10px 20px rgba(13, 110, 253, 0.15) !important;
    }
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}