@page
@model RegisterModel
@{
    ViewData["Title"] = "Đăng ký tài khoản";
}

<div class="container py-3">
    <div class="row align-items-center">
        <!-- Cột trái: Giới thiệu sản phẩm -->
        <div class="col-lg-6 mb-4 mb-lg-0 pe-lg-5">
            <h2 class="display-6 fw-bold mb-4" style="color: #e53935; line-height: 1.3;">
                Giải pháp vay vốn trực tuyến siêu tốc!
            </h2>

            <div class="d-flex mb-3 align-items-start">
                <div class="text-warning me-3 fs-4"><i class="bi bi-lightning-charge-fill"></i></div>
                <div>
                    <h6 class="fw-bold mb-1 text-dark">Duyệt hồ sơ tự động bằng AI trong 5 phút</h6>
                </div>
            </div>

            <div class="d-flex mb-3 align-items-start">
                <div class="text-warning me-3 fs-4"><i class="bi bi-shield-check"></i></div>
                <div>
                    <h6 class="fw-bold mb-1 text-dark">Lãi suất minh bạch, hạn mức lên đến 500 triệu</h6>
                </div>
            </div>

            <div class="d-flex mb-3 align-items-start">
                <div class="text-warning me-3 fs-4"><i class="bi bi-phone"></i></div>
                <div>
                    <h6 class="fw-bold mb-1 text-dark">100% Online, không cần thế chấp tài sản</h6>
                </div>
            </div>
        </div>

        <!-- Cột phải: Form đăng ký -->
        <div class="col-lg-5 offset-lg-1">
            <div class="card border-0 shadow-lg rounded-4 p-4">
                <h3 class="fw-bold mb-1" style="color: #e53935;">ĐĂNG KÝ</h3>
                <p class="text-muted mb-3 fs-6">Nhanh chóng, dễ dàng</p>

                <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-2" role="alert"></div>

                    <div class="form-floating mb-2">
                        <input asp-for="Input.FullName" class="form-control form-control-sm rounded-3" autocomplete="name" aria-required="true" placeholder="Họ và tên" />
                        <label asp-for="Input.FullName">Họ và tên <span class="text-danger">*</span></label>
                        <span asp-validation-for="Input.FullName" class="text-danger small"></span>
                    </div>

                    <div class="form-floating mb-2">
                        <input asp-for="Input.PhoneNumber" class="form-control form-control-sm rounded-3" autocomplete="tel" aria-required="true" placeholder="Số điện thoại" />
                        <label asp-for="Input.PhoneNumber">Số điện thoại <span class="text-danger">*</span></label>
                        <span asp-validation-for="Input.PhoneNumber" class="text-danger small"></span>
                    </div>

                    <div class="form-floating mb-2">
                        <input asp-for="Input.Email" class="form-control form-control-sm rounded-3" autocomplete="username" aria-required="true" placeholder="Email" />
                        <label asp-for="Input.Email">Email <span class="text-danger">*</span></label>
                        <span asp-validation-for="Input.Email" class="text-danger small"></span>
                    </div>

                    <div class="form-floating mb-2">
                        <input asp-for="Input.Password" class="form-control form-control-sm rounded-3" autocomplete="new-password" aria-required="true" placeholder="Mật khẩu" />
                        <label asp-for="Input.Password">Mật khẩu <span class="text-danger">*</span></label>
                        <span asp-validation-for="Input.Password" class="text-danger small"></span>
                    </div>

                    <div class="form-floating mb-3">
                        <input asp-for="Input.ConfirmPassword" class="form-control form-control-sm rounded-3" autocomplete="new-password" aria-required="true" placeholder="Xác nhận mật khẩu" />
                        <label asp-for="Input.ConfirmPassword">Xác nhận mật khẩu <span class="text-danger">*</span></label>
                        <span asp-validation-for="Input.ConfirmPassword" class="text-danger small"></span>
                    </div>

                    <button id="registerSubmit" type="submit" class="btn btn-danger w-100 py-2 rounded-3 fw-bold mb-2 shadow-sm" style="background-color: #e53935; border: none;">
                        ĐĂNG KÝ NGAY
                    </button>

                </form>

                <div class="text-center mb-2 position-relative">
                    <hr class="text-muted my-2">
                    <span class="bg-white px-2 text-dark fw-bold position-absolute top-50 start-50 translate-middle small">Hoặc</span>
                </div>

                <!-- FORM ĐĂNG NHẬP GOOGLE (Đã tách rời hoàn toàn khỏi form đăng ký) -->
                <form id="external-account" asp-page="./ExternalLogin" asp-route-returnUrl="@Model.ReturnUrl" method="post" class="form-horizontal">
                    <button type="submit" name="provider" value="Google" class="btn btn-outline-dark w-100 py-2 rounded-3 mb-3 d-flex justify-content-center align-items-center fw-semibold small" formnovalidate>
                        <img src="https://upload.wikimedia.org/wikipedia/commons/c/c1/Google_%22G%22_logo.svg" alt="Google" style="width: 18px; height: 18px; margin-right: 10px;">
                        Tiếp tục với Google
                    </button>
                </form>

                <p class="text-center text-muted mb-0" style="font-size: 0.7rem;">
                    Bằng việc Đăng ký, bạn đã đồng ý với <a href="#" class="text-danger text-decoration-none">Điều khoản</a> và <a href="#" class="text-danger text-decoration-none">Chính sách bảo mật</a> của FastLoan.
                </p>

                <div class="text-center mt-2 pt-2 border-top">
                    <p class="mb-0 text-muted small">Bạn đã có tài khoản? <a asp-page="./Login" asp-route-returnUrl="@Model.ReturnUrl" class="text-primary text-decoration-none fw-bold">Đăng nhập</a></p>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}