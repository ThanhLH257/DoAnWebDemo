@model DoAnWebDemo.Models.ApplicationUser
@{
    ViewData["Title"] = "Xóa Tài Khoản";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-5">
    <div class="row justify-content-center text-center">
        <div class="col-md-6">
            <div class="card border-0 shadow-lg rounded-5 overflow-hidden p-5">
                <div class="d-inline-flex align-items-center justify-content-center bg-danger bg-opacity-10 rounded-circle mb-4 shadow-sm" style="width: 100px; height: 100px;">
                    <i class="bi bi-person-x-fill text-danger" style="font-size: 3rem;"></i>
                </div>
                <h3 class="fw-black text-dark mb-2">Gỡ bỏ tài khoản?</h3>
                <p class="text-secondary mb-4">Hành động này sẽ xóa vĩnh viễn tài khoản <strong>@Model.Email</strong>. Khách hàng sẽ không thể đăng nhập được nữa.</p>

                <form asp-action="Delete" method="post">
                    <input type="hidden" name="id" value="@Model.Id" />
                    <div class="d-grid gap-3">
                        <button type="submit" class="btn btn-danger py-3 rounded-pill fw-bold shadow-sm hover-lift">
                            <i class="bi bi-trash3-fill me-2"></i> XÁC NHẬN XÓA
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary py-3 rounded-pill fw-bold">Không, quay lại</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>