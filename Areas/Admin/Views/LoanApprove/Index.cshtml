@model IEnumerable<DoAnWebDemo.Models.LoanApplication>

@{
    ViewData["Title"] = "Quản lý Đơn vay - Admin";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-primary m-0"><i class="bi bi-file-earmark-check"></i> Phê duyệt & Giải ngân</h2>

        <!-- Nút Quét Phạt Trễ Hạn (F11) -->
        <form asp-area="Admin" asp-controller="LoanApprove" asp-action="ApplyPenalty" method="post">
            <button type="submit" class="btn btn-danger btn-lg fw-bold shadow-sm" onclick="return confirm('Hệ thống sẽ quét và cộng 50.000đ vào các kỳ trễ hạn. Bạn chắc chứ?');">
                <i class="bi bi-exclamation-triangle-fill"></i> QUÉT PHẠT TRỄ HẠN
            </button>
        </form>
    </div>

    <!-- Hiển thị thông báo khi Giải ngân hoặc Phạt thành công -->
    @if (TempData["Message"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm fw-bold" role="alert">
            <i class="bi bi-check-circle-fill"></i> @TempData["Message"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="table-responsive shadow-sm rounded">
        <table class="table table-bordered table-hover align-middle mb-0">
            <thead class="table-dark">
                <tr>
                    <th>Khách hàng</th>
                    <th>Liên hệ / CCCD</th>
                    <th>Gói vay</th>
                    <th>Số tiền / Điểm TD</th>
                    <th>Kỳ hạn</th>
                    <th>Trạng thái</th>
                    <th>Hành động</th>
                </tr>
            </thead>
            <tbody class="bg-white">
                @foreach (var item in Model)
                {
                    <tr>
                        <td><strong class="text-primary">@item.User?.FullName</strong></td>
                        <td>
                            @item.User?.PhoneNumber <br />
                            <small class="text-muted">CCCD: @item.User?.CCCD</small>
                        </td>
                        <td>@item.Package?.PackageName</td>
                        <td>
                            <strong class="text-danger">@item.LoanAmount.ToString("#,##0") đ</strong><br />
                            <span class="badge bg-info text-dark">Điểm TD: @item.CreditScore</span>
                        </td>
                        <td>@item.TermMonths tháng</td>
                        <td>
                            @if (item.Status == "Pending")
                            {
                                <span class="badge bg-warning text-dark">Chờ duyệt</span>
                            }
                            else if (item.Status == "Approved")
                            {
                                <span class="badge bg-primary">Chờ giải ngân</span>
                            }
                            else if (item.Status == "Active")
                            {
                                <span class="badge bg-success">Đang hoạt động</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">@item.Status</span>
                            }
                        </td>
                        <td>
                            <div class="d-flex gap-2">
                                @if (item.Status == "Pending")
                                {
                                    <!-- Trạng thái Chờ duyệt: Hiển thị nút Duyệt / Từ chối -->
                                    <form asp-area="Admin" asp-controller="LoanApprove" asp-action="Approve" asp-route-id="@item.Id" method="post">
                                        <button type="submit" class="btn btn-success btn-sm"><i class="bi bi-check-lg"></i> Duyệt</button>
                                    </form>
                                    <form asp-area="Admin" asp-controller="LoanApprove" asp-action="Reject" asp-route-id="@item.Id" method="post">
                                        <button type="submit" class="btn btn-outline-danger btn-sm" onclick="return confirm('Bạn chắc chắn muốn từ chối đơn này?');">Từ chối</button>
                                    </form>
                                }
                                else if (item.Status == "Approved")
                                {
                                    <!-- Trạng thái Đã duyệt: Hiển thị nút Giải ngân (F8) -->
                                    <form asp-area="Admin" asp-controller="LoanApprove" asp-action="Disburse" asp-route-id="@item.Id" method="post">
                                        <button type="submit" class="btn btn-primary btn-sm fw-bold shadow-sm">
                                            <i class="bi bi-cash-coin"></i> Giải ngân ngay
                                        </button>
                                    </form>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>