<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - FastLoan VN</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/DoAnWebDemo.styles.css" asp-append-version="true" />

    <!-- Tích hợp thư viện Icon của Bootstrap -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <!-- Tích hợp Font chữ Inter chuẩn UI/UX hiện đại -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

    <style>
        /* Ép Font chữ và cấu hình Footer luôn nằm dưới cùng */
        body {
            font-family: 'Inter', sans-serif;
            background-color: #f8f9fa;
            display: flex;
            flex-direction: column;
            min-height: 100vh;
            margin-bottom: 0 !important; /* Xóa bỏ khoảng trắng 60px mặc định của ASP.NET trong file site.css */
        }

        .navbar-brand {
            font-size: 1.6rem;
            letter-spacing: 0.5px;
        }

        .nav-link {
            font-weight: 500;
            transition: color 0.3s ease, transform 0.2s ease;
        }

            .nav-link:hover {
                color: #e0f7fa !important;
                transform: translateY(-1px);
            }

        .footer-link {
            color: #adb5bd;
            text-decoration: none;
            transition: color 0.3s, padding-left 0.3s;
        }

            .footer-link:hover {
                color: #ffffff;
                padding-left: 5px;
            }
    </style>
</head>
<body>
    <header class="sticky-top">
        <!-- Đổi màu thanh Nav thành xanh dương đậm của Ngân hàng -->
        <nav class="navbar navbar-expand-lg navbar-dark bg-primary border-bottom shadow-sm py-3">
            <div class="container-fluid px-4 px-lg-5">
                <a class="navbar-brand fw-extrabold" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-bank2 me-2 text-warning"></i>Fast<span class="text-warning">Loan</span>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1 ms-lg-4">
                        <li class="nav-item">
                            <a class="nav-link text-white px-3" asp-area="" asp-controller="Home" asp-action="Index">
                                <i class="bi bi-house-door me-1"></i> Trang chủ
                            </a>
                        </li>

                        <!-- Menu thông minh: Chỉ hiện khi ĐÃ ĐĂNG NHẬP -->
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            // Nếu là ADMIN -> Hiện menu của Admin
                            if (User.IsInRole("Admin"))
                            {
                                <li class="nav-item dropdown">
                                    <a class="nav-link dropdown-toggle text-white px-3" href="#" id="adminMenu" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                        <i class="bi bi-shield-lock me-1"></i> Quản trị Admin
                                    </a>
                                    <ul class="dropdown-menu shadow-lg border-0 mt-2 rounded-3" aria-labelledby="adminMenu">
                                        <li><a class="dropdown-item py-2 fw-semibold text-secondary" asp-area="Admin" asp-controller="Home" asp-action="Index"><i class="bi bi-speedometer2 text-primary me-2"></i> Dashboard Thống Kê</a></li>
                                        <li><a class="dropdown-item py-2 fw-semibold text-secondary" asp-area="Admin" asp-controller="LoanApprove" asp-action="Index"><i class="bi bi-file-earmark-check text-success me-2"></i> Duyệt Đơn & Giải Ngân</a></li>
                                        <li><hr class="dropdown-divider"></li>
                                        <li><a class="dropdown-item py-2 fw-semibold text-secondary" asp-area="" asp-controller="LoanPackages" asp-action="Index"><i class="bi bi-box-seam text-warning me-2"></i> Quản lý Gói Vay</a></li>
                                    </ul>
                                </li>
                            }
                            // Nếu là KHÁCH HÀNG -> Hiện menu của Khách
                            else
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-white px-3" asp-area="" asp-controller="LoanApplications" asp-action="Create">
                                        <i class="bi bi-pencil-square me-1"></i> Nộp Đơn Vay
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-white px-3" asp-area="" asp-controller="Payment" asp-action="Index">
                                        <i class="bi bi-calendar-check me-1"></i> Lịch Trả Nợ
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-white px-3" asp-area="" asp-controller="Profile" asp-action="Index">
                                        <i class="bi bi-person-badge me-1"></i> Hồ sơ eKYC
                                    </a>
                                </li>
                            }
                        }
                    </ul>
                    <!-- Component Login góc phải -->
                    <div class="d-flex align-items-center">
                        <partial name="_LoginPartial" />
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <!-- Bỏ thẻ container bao quanh RenderBody để Landing Page được tràn màn hình -->
    <main role="main" class="flex-grow-1 pb-5">
        @RenderBody()
    </main>

    <!-- Khu vực Footer Khổng Lồ -->
    <footer class="bg-dark text-light pt-5 pb-4 mt-auto">
        <div class="container px-4">
            <div class="row text-center text-md-start">
                <!-- Cột Thương hiệu -->
                <div class="col-md-4 col-lg-4 col-xl-4 mx-auto mb-4">
                    <h5 class="text-uppercase fw-extrabold mb-4 fs-4">
                        <i class="bi bi-bank2 me-2 text-warning"></i>Fast<span class="text-warning">Loan</span> VN
                    </h5>
                    <p class="text-secondary lh-lg">
                        Giải pháp tài chính thông minh, minh bạch và an toàn. Chúng tôi cung cấp các gói vay trực tuyến duyệt tự động bằng công nghệ AI 24/7, giúp bạn giải quyết nhu cầu vốn nhanh nhất.
                    </p>
                    <div class="mt-4">
                        <a href="#" class="btn btn-outline-secondary btn-sm rounded-circle me-2"><i class="bi bi-facebook"></i></a>
                        <a href="#" class="btn btn-outline-secondary btn-sm rounded-circle me-2"><i class="bi bi-youtube"></i></a>
                        <a href="#" class="btn btn-outline-secondary btn-sm rounded-circle me-2"><i class="bi bi-linkedin"></i></a>
                        <a href="#" class="btn btn-outline-secondary btn-sm rounded-circle"><i class="bi bi-tiktok"></i></a>
                    </div>
                </div>

                <!-- Cột Liên kết 1 -->
                <div class="col-md-2 col-lg-2 col-xl-2 mx-auto mb-4 mt-2">
                    <h6 class="text-uppercase fw-bold mb-4">Về chúng tôi</h6>
                    <p><a href="#!" class="footer-link"><i class="bi bi-chevron-right small text-secondary"></i> Câu chuyện FastLoan</a></p>
                    <p><a href="#!" class="footer-link"><i class="bi bi-chevron-right small text-secondary"></i> Các gói vay</a></p>
                    <p><a href="#!" class="footer-link"><i class="bi bi-chevron-right small text-secondary"></i> Biểu phí & Lãi suất</a></p>
                    <p><a href="#!" class="footer-link"><i class="bi bi-chevron-right small text-secondary"></i> Tuyển dụng</a></p>
                </div>

                <!-- Cột Liên kết 2 -->
                <div class="col-md-3 col-lg-2 col-xl-2 mx-auto mb-4 mt-2">
                    <h6 class="text-uppercase fw-bold mb-4">Hỗ trợ khách hàng</h6>
                    <p><a href="#!" class="footer-link"><i class="bi bi-chevron-right small text-secondary"></i> Hướng dẫn vay vốn</a></p>
                    <p><a href="#!" class="footer-link"><i class="bi bi-chevron-right small text-secondary"></i> Hướng dẫn thanh toán</a></p>
                    <p><a href="#!" class="footer-link"><i class="bi bi-chevron-right small text-secondary"></i> Câu hỏi thường gặp</a></p>
                    <p><a href="#!" class="footer-link"><i class="bi bi-chevron-right small text-secondary"></i> Chính sách bảo mật</a></p>
                </div>

                <!-- Cột Thông tin liên hệ -->
                <div class="col-md-3 col-lg-4 col-xl-3 mx-auto mb-4 mt-2">
                    <h6 class="text-uppercase fw-bold mb-4">Thông tin liên hệ</h6>
                    <p class="text-secondary"><i class="bi bi-geo-alt-fill me-3 text-light"></i> Khu Công Nghệ Cao, Tp.Thủ Đức, TP.HCM</p>
                    <p class="text-secondary"><i class="bi bi-envelope-fill me-3 text-light"></i> hotro@fastloan.demo.vn</p>
                    <p class="text-secondary"><i class="bi bi-telephone-fill me-3 text-light"></i> 1900 9999 (Hỗ trợ 24/7)</p>
                    <p class="text-secondary"><i class="bi bi-clock-fill me-3 text-light"></i> T2 - T6: 08:00 - 18:00</p>
                </div>
            </div>

            <hr class="mb-4 bg-secondary" style="opacity: 0.3;" />

            <!-- Cột Bản quyền và Logo Chứng nhận -->
            <div class="row align-items-center">
                <div class="col-md-7 col-lg-8">
                    <p class="text-secondary mb-0 fw-medium">
                        &copy; 2026 FastLoan FinTech. Đồ án lập trình Web - Nhóm 5. All rights reserved.
                    </p>
                </div>
                <div class="col-md-5 col-lg-4 text-center text-md-end mt-3 mt-md-0">
                    <span class="badge bg-secondary bg-opacity-25 text-light px-3 py-2 rounded-pill">
                        <i class="bi bi-shield-check text-success me-1"></i> Chứng nhận bảo mật PCI DSS
                    </span>
                </div>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>