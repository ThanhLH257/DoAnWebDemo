@model DoAnWebDemo.Models.LoanPackage

@{
    ViewData["Title"] = "Chi Tiết Gói Vay";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden mb-4">
                <!-- Header: Đồng bộ màu sắc với hệ thống -->
                <div class="card-header bg-info bg-gradient py-4 px-4 d-flex justify-content-between align-items-center border-0">
                    <h4 class="fw-bold text-white mb-0"><i class="bi bi-info-circle-fill me-2"></i> @ViewData["Title"]</h4>
                    <span class="badge bg-white text-info rounded-pill px-3 py-2 fw-bold shadow-sm">ID: #@Model.Id</span>
                </div>

                <div class="card-body p-0">
                    <!-- Phần giới thiệu tên gói vay -->
                    <div class="bg-light p-4 border-bottom">
                        <div class="row align-items-center">
                            <div class="col-md-auto mb-3 mb-md-0">
                                <div class="bg-white p-3 rounded-circle shadow-sm">
                                    <i class="bi bi-wallet2 text-primary" style="font-size: 2.5rem;"></i>
                                </div>
                            </div>
                            <div class="col">
                                <h3 class="fw-bold text-dark mb-1">@Model.PackageName</h3>
                                <p class="text-muted mb-0">Thông tin chi tiết về sản phẩm tín dụng của hệ thống FastLoan VN</p>
                            </div>
                        </div>
                    </div>

                    <!-- Phần thông số chính: Đã loại bỏ Phân Khúc và chia lại bố cục 2 cột -->
                    <div class="p-4 p-md-5">
                        <div class="row g-4 text-center">
                            <div class="col-md-6">
                                <div class="p-4 bg-light rounded-4 border-start border-4 border-primary shadow-sm">
                                    <div class="text-muted small fw-bold mb-2 text-uppercase">Lãi Suất Áp Dụng</div>
                                    <div class="h2 fw-extrabold text-primary mb-1">@Model.InterestRate%</div>
                                    <div class="text-muted small italic">mỗi tháng</div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="p-4 bg-light rounded-4 border-start border-4 border-dark shadow-sm">
                                    <div class="text-muted small fw-bold mb-2 text-uppercase">Kỳ Hạn Vay Tối Đa</div>
                                    <div class="h2 fw-extrabold text-dark mb-1">@Model.DefaultTermMonths</div>
                                    <div class="text-muted small italic">tháng</div>
                                </div>
                            </div>
                        </div>

                        <!-- Phần hạn mức vay thực tế từ CSDL -->
                        <div class="mt-5 pt-4 border-top">
                            <div class="d-flex justify-content-between align-items-end mb-3">
                                <h6 class="fw-bold text-secondary mb-0 text-uppercase small">Hạn mức giải ngân dự kiến</h6>
                                <span class="badge bg-success bg-opacity-10 text-success rounded-pill px-3">Khả dụng</span>
                            </div>

                            <div class="row g-3">
                                <div class="col-6">
                                    <div class="p-3 bg-white border rounded-3">
                                        <div class="small text-muted mb-1">Hạn mức thấp nhất:</div>
                                        <div class="fw-bold text-dark fs-5">@Model.MinAmount.ToString("#,##0") <span class="small fw-normal">VNĐ</span></div>
                                    </div>
                                </div>
                                <div class="col-6">
                                    <div class="p-3 bg-white border rounded-3 text-end">
                                        <div class="small text-muted mb-1">Hạn mức cao nhất:</div>
                                        <div class="fw-bold text-danger fs-5">@Model.MaxAmount.ToString("#,##0") <span class="small fw-normal">VNĐ</span></div>
                                    </div>
                                </div>
                            </div>

                            <div class="progress mt-4 rounded-pill" style="height: 8px;">
                                <div class="progress-bar bg-success progress-bar-striped progress-bar-animated" style="width: 100%"></div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card-footer bg-white border-0 py-4 px-4 text-end">
                    <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4 fw-bold me-2">
                        <i class="bi bi-arrow-left me-1"></i> QUAY LẠI
                    </a>

                    @if (User.IsInRole("Admin"))
                    {
                        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning rounded-pill px-4 fw-bold shadow-sm">
                            <i class="bi bi-pencil-square me-1"></i> CHỈNH SỬA GÓI VAY
                        </a>
                    }
                    else if (User.Identity.IsAuthenticated)
                    {
                        <a asp-controller="LoanApplications" asp-action="Create" asp-route-packageId="@Model.Id" class="btn btn-primary rounded-pill px-4 fw-bold shadow-sm">
                            <i class="bi bi-send-fill me-1"></i> ĐĂNG KÝ VAY NGAY
                        </a>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .fw-extrabold {
        font-weight: 800;
    }

    .italic {
        font-style: italic;
    }
</style>