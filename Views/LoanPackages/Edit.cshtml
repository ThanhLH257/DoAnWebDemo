@model DoAnWebDemo.Models.LoanPackage

@{
    ViewData["Title"] = "Cập Nhật Gói Vay";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-7">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                <div class="card-header bg-warning py-4 text-center">
                    <h3 class="fw-bold text-dark mb-0"><i class="bi bi-pencil-square me-2"></i> @ViewData["Title"]</h3>
                    <p class="text-dark opacity-75 mb-0 small">Mã định danh gói vay: #@Model.Id</p>
                </div>
                <div class="card-body p-4 p-md-5">
                    <form asp-action="Edit">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-3 border-0 mb-4" role="alert"></div>
                        <input type="hidden" asp-for="Id" />

                        <div class="row g-4">
                            <div class="col-12">
                                <div class="form-floating shadow-sm">
                                    <input asp-for="PackageName" class="form-control rounded-3 border-0 bg-light fw-bold" placeholder="Tên gói" />
                                    <label asp-for="PackageName" class="text-muted fw-bold small">Tên sản phẩm gói vay</label>
                                </div>
                                <span asp-validation-for="PackageName" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <div class="form-floating shadow-sm">
                                    <input asp-for="InterestRate" class="form-control rounded-3 border-0 bg-light" />
                                    <label asp-for="InterestRate" class="text-muted fw-bold small">Lãi suất hàng tháng (%)</label>
                                </div>
                                <span asp-validation-for="InterestRate" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <div class="form-floating shadow-sm">
                                    <input asp-for="DefaultTermMonths" class="form-control rounded-3 border-0 bg-light" />
                                    <label asp-for="DefaultTermMonths" class="text-muted fw-bold small">Kỳ hạn tối đa (Tháng)</label>
                                </div>
                                <span asp-validation-for="DefaultTermMonths" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <div class="form-floating shadow-sm">
                                    <input asp-for="MinAmount" class="form-control rounded-3 border-0 bg-light text-success" />
                                    <label asp-for="MinAmount" class="text-muted fw-bold small">Số tiền vay tối thiểu</label>
                                </div>
                                <span asp-validation-for="MinAmount" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <div class="form-floating shadow-sm">
                                    <input asp-for="MaxAmount" class="form-control rounded-3 border-0 bg-light text-danger" />
                                    <label asp-for="MaxAmount" class="text-muted fw-bold small">Số tiền vay tối đa</label>
                                </div>
                                <span asp-validation-for="MaxAmount" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="mt-5 d-grid gap-2">
                            <button type="submit" class="btn btn-warning btn-lg py-3 rounded-pill fw-bold shadow-sm hover-lift text-dark">
                                <i class="bi bi-save2-fill me-2"></i> LƯU THAY ĐỔI
                            </button>
                            <a asp-action="Index" class="btn btn-link text-secondary text-decoration-none text-center mt-2">Hủy bỏ và quay lại</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}