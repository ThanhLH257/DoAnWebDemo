@model IEnumerable<DoAnWebDemo.Models.LoanPackage>

@{
    ViewData["Title"] = "Danh sách Gói Vay";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-primary m-0"><i class="bi bi-box-seam-fill me-2"></i> @ViewData["Title"]</h2>
            <p class="text-muted small mb-0">Lựa chọn giải pháp tài chính phù hợp với nhu cầu của bạn</p>
        </div>

        @* F1: Chỉ Admin mới thấy nút "Tạo mới" *@
        @if (User.IsInRole("Admin"))
        {
            <a asp-action="Create" class="btn btn-primary rounded-pill px-4 fw-bold shadow-sm">
                <i class="bi bi-plus-circle-fill me-2"></i> Tạo Gói Vay Mới
            </a>
        }
    </div>

    <div class="row g-4">
        @foreach (var item in Model)
        {
            <div class="col-md-6 col-lg-4">
                <div class="card h-100 border-0 shadow-sm rounded-4 overflow-hidden hover-lift transition-all">
                    <!-- Header màu sắc theo lãi suất hoặc mặc định -->
                    <div class="bg-primary bg-gradient py-3 px-4 text-white">
                        <div class="d-flex justify-content-between align-items-center">
                            <h5 class="fw-bold mb-0">@item.PackageName</h5>
                            <span class="badge bg-white text-primary rounded-pill">Lãi @item.InterestRate%/tháng</span>
                        </div>
                    </div>

                    <div class="card-body p-4">
                        <div class="mb-4">
                            <div class="d-flex justify-content-between mb-2">
                                <span class="text-muted small">Hạn mức vay:</span>
                                <span class="fw-bold text-dark">@item.MinAmount.ToString("#,##0") - @item.MaxAmount.ToString("#,##0") đ</span>
                            </div>
                            <div class="d-flex justify-content-between mb-2">
                                <span class="text-muted small">Kỳ hạn tối đa:</span>
                                <span class="fw-bold text-dark">@item.DefaultTermMonths tháng</span>
                            </div>
                        </div>

                        <div class="d-grid gap-2">
                            @* Nút xem chi tiết luôn hiện cho mọi người *@
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-primary rounded-pill fw-bold">
                                <i class="bi bi-info-circle me-1"></i> Xem chi tiết
                            </a>

                            @* F2: Chỉ Admin mới thấy các nút điều chỉnh (Edit/Delete) *@
                            @if (User.IsInRole("Admin"))
                            {
                                <div class="d-flex gap-2 mt-2 pt-2 border-top">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-light text-warning flex-fill rounded-pill fw-bold border">
                                        <i class="bi bi-pencil-square"></i> Sửa
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-light text-danger flex-fill rounded-pill fw-bold border">
                                        <i class="bi bi-trash3"></i> Xóa
                                    </a>
                                </div>
                            }
                            else if (User.Identity.IsAuthenticated)
                            {
                                @* Nếu là Khách hàng: Hiện nút đăng ký vay trực tiếp *@
                                <a asp-controller="LoanApplications" asp-action="Create" asp-route-packageId="@item.Id" class="btn btn-success rounded-pill fw-bold">
                                    <i class="bi bi-pencil-square me-1"></i> Đăng ký vay ngay
                                </a>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<style>
    .hover-lift:hover {
        transform: translateY(-5px);
        box-shadow: 0 1rem 3rem rgba(0,0,0,.1) !important;
    }

    .transition-all {
        transition: all 0.3s ease;
    }
</style>