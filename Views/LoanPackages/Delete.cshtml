@model DoAnWebDemo.Models.LoanPackage

@{
    ViewData["Title"] = "Xóa Gói Vay";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-5">
    <div class="row justify-content-center text-center">
        <div class="col-lg-6">
            <div class="card border-0 shadow-lg rounded-5 overflow-hidden p-5">
                <div class="mb-4">
                    <div class="d-inline-flex align-items-center justify-content-center bg-danger bg-opacity-10 rounded-circle mb-3 shadow-sm" style="width: 100px; height: 100px;">
                        <i class="bi bi-trash3-fill text-danger" style="font-size: 3rem;"></i>
                    </div>
                    <h2 class="fw-extrabold text-dark mb-2">Gỡ bỏ gói vay?</h2>
                    <p class="text-secondary mb-0">Bạn đang yêu cầu xóa gói vay <strong>"@Model.PackageName"</strong> khỏi danh mục kinh doanh.</p>
                </div>

                <div class="alert alert-warning border-0 rounded-4 text-start p-4 mb-4">
                    <div class="d-flex align-items-start">
                        <i class="bi bi-exclamation-triangle-fill fs-3 me-3"></i>
                        <div>
                            <h6 class="fw-bold mb-1">CẢNH BÁO HỆ THỐNG!</h6>
                            <p class="mb-0 small opacity-75">Hành động này có thể gây lỗi cho các Đơn vay đang tham chiếu tới gói vay này. Chúng tôi khuyến nghị chỉ xóa nếu chưa có khách hàng nào nộp đơn vào gói này.</p>
                        </div>
                    </div>
                </div>

                <div class="bg-light p-4 rounded-4 mb-5 text-start border border-white">
                    <div class="row g-3">
                        <div class="col-6">
                            <span class="text-muted small d-block">Lãi suất:</span>
                            <span class="fw-bold text-dark">@Model.InterestRate%/tháng</span>
                        </div>
                        <div class="col-6">
                            <span class="text-muted small d-block">Kỳ hạn:</span>
                            <span class="fw-bold text-dark">@Model.DefaultTermMonths tháng</span>
                        </div>
                        <div class="col-12 border-top pt-2 mt-2">
                            <span class="text-muted small d-block">Hạn mức tối đa:</span>
                            <span class="fw-bold text-danger">@Model.MaxAmount.ToString("#,##0") VNĐ</span>
                        </div>
                    </div>
                </div>

                <form asp-action="Delete">
                    <input type="hidden" asp-for="Id" />
                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-danger btn-lg py-3 rounded-pill fw-bold shadow-sm hover-lift">
                            <i class="bi bi-trash3-fill me-2"></i> XÁC NHẬN XÓA NGAY
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary py-3 rounded-pill fw-bold border-0">Không, quay lại danh sách</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<style>
    .fw-extrabold {
        font-weight: 800;
    }

    .hover-lift:hover {
        transform: translateY(-3px);
        box-shadow: 0 10px 20px rgba(220, 53, 69, 0.2) !important;
    }
</style>