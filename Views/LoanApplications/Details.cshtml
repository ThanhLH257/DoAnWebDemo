@model DoAnWebDemo.Models.LoanApplication

@{
    ViewData["Title"] = "Chi tiết hồ sơ vay";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="card border-0 shadow-lg rounded-5 overflow-hidden">
                <div class="card-header bg-dark p-4 p-md-5 border-0 d-flex justify-content-between align-items-center">
                    <div>
                        <h3 class="text-white fw-black mb-1">HỒ SƠ VAY #@Model.Id</h3>
                        <p class="text-white-50 mb-0 small">Ngày khởi tạo: @Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</p>
                    </div>
                    <div class="text-end">
                        @if (Model.Status == "Pending")
                        {
                            <span class="badge bg-warning rounded-pill px-4 py-2 fw-bold">CHỜ DUYỆT</span>
                        }
                        else if (Model.Status == "Approved")
                        {
                            <span class="badge bg-success rounded-pill px-4 py-2 fw-bold">ĐÃ PHÊ DUYỆT</span>
                        }
                        else
                        {
                            <span class="badge bg-danger rounded-pill px-4 py-2 fw-bold">TỪ CHỐI</span>
                        }
                    </div>
                </div>

                <div class="card-body p-4 p-md-5 bg-white">
                    <div class="row g-4">
                        <!-- Thông tin khách hàng -->
                        <div class="col-md-6 border-end border-light">
                            <h6 class="text-primary fw-bold text-uppercase mb-4 ls-1">Khách hàng</h6>
                            <div class="d-flex align-items-center mb-4">
                                <div class="bg-primary bg-opacity-10 p-3 rounded-circle me-3">
                                    <i class="bi bi-person-badge-fill text-primary fs-3"></i>
                                </div>
                                <div>
                                    <h5 class="fw-black text-dark mb-0">@Model.User?.FullName</h5>
                                    <p class="text-muted small mb-0">@Model.User?.Email</p>
                                </div>
                            </div>
                            <div class="p-3 bg-light rounded-4">
                                <div class="d-flex justify-content-between mb-2">
                                    <small class="text-secondary">Điểm tín dụng AI:</small>
                                    <span class="fw-black text-primary">@Model.CreditScore / 1000</span>
                                </div>
                                <div class="progress rounded-pill" style="height: 6px;">
                                    <div class="progress-bar bg-primary" style="width: @(Model.CreditScore / 10)%"></div>
                                </div>
                            </div>
                        </div>

                        <!-- Thông tin tài chính -->
                        <div class="col-md-6">
                            <h6 class="text-primary fw-bold text-uppercase mb-4 ls-1">Khoản vay</h6>
                            <div class="row g-3">
                                <div class="col-6">
                                    <small class="text-muted d-block">Số tiền vay</small>
                                    <h4 class="fw-black text-danger">@Model.LoanAmount.ToString("#,##0") đ</h4>
                                </div>
                                <div class="col-6">
                                    <small class="text-muted d-block">Gói vay</small>
                                    <span class="fw-bold text-dark">@Model.Package?.PackageName</span>
                                </div>
                                <div class="col-6">
                                    <small class="text-muted d-block">Kỳ hạn</small>
                                    <span class="fw-bold text-dark">@Model.TermMonths tháng</span>
                                </div>
                                <div class="col-6">
                                    <small class="text-muted d-block">Lãi suất gói</small>
                                    <span class="fw-bold text-success">@Model.Package?.InterestRate%/tháng</span>
                                </div>
                            </div>
                        </div>

                        <div class="col-12 mt-5">
                            <h6 class="text-primary fw-bold text-uppercase mb-3 ls-1">Mục đích sử dụng vốn</h6>
                            <div class="p-4 bg-light rounded-4 border-start border-primary border-4 italic text-secondary">
                                "@Model.Purpose"
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card-footer bg-light p-4 text-end border-0">
                    <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4 fw-bold me-2">QUAY LẠI</a>
                    @if (User.IsInRole("Admin") || Model.Status == "Pending")
                    {
                        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning rounded-pill px-4 fw-bold shadow-sm">SỬA HỒ SƠ</a>
                    }
                </div>
            </div>
        </div>
    </div>
</div>