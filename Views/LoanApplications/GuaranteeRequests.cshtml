@model IEnumerable<DoAnWebDemo.Models.LoanApplication>
@{
    ViewData["Title"] = "Yêu Cầu Bảo Lãnh";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-5">
    <h3 class="fw-black text-dark mb-4"><i class="bi bi-shield-check text-success me-2"></i> DANH SÁCH YÊU CẦU BẢO LÃNH TÍN DỤNG</h3>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success border-0 shadow-sm rounded-4 mb-4 fw-bold">@TempData["SuccessMessage"]</div>
    }

    @if (!Model.Any())
    {
        <div class="alert alert-info border-0 rounded-4 shadow-sm p-4 text-center">
            <i class="bi bi-inbox fs-1 d-block mb-3 text-secondary"></i>
            Bạn không có yêu cầu bảo lãnh nào đang chờ xử lý.
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var item in Model)
            {
                <div class="col-md-6">
                    <div class="card border-0 shadow-lg rounded-4 overflow-hidden border-top border-4 border-warning">
                        <div class="card-body p-4">
                            <h5 class="fw-bold">@item.User?.FullName <span class="text-muted fs-6 fw-normal">đang yêu cầu bạn bảo lãnh</span></h5>
                            <hr />
                            <p class="mb-1"><strong>Số tiền vay:</strong> <span class="text-danger fw-bold">@item.LoanAmount.ToString("#,##0") đ</span></p>
                            <p class="mb-1"><strong>Gói vay:</strong> @item.Package?.PackageName</p>
                            <p class="mb-3"><strong>Mục đích:</strong> @item.Purpose</p>

                            <div class="alert alert-warning bg-warning bg-opacity-10 border-0 x-small rounded-3">
                                <strong>Lưu ý pháp lý:</strong> Bằng việc chấp nhận, bạn cam kết sẽ chịu trách nhiệm thanh toán khoản nợ này trong trường hợp người vay mất khả năng chi trả.
                            </div>

                            <div class="d-flex gap-2 mt-4">
                                <form asp-action="AcceptGuarantee" asp-route-id="@item.Id" method="post" class="flex-fill">
                                    <button type="submit" class="btn btn-success w-100 rounded-pill fw-bold" onclick="return confirm('Xác nhận đồng ý bảo lãnh?');">CHẤP NHẬN</button>
                                </form>
                                <form asp-action="RejectGuarantee" asp-route-id="@item.Id" method="post" class="flex-fill">
                                    <button type="submit" class="btn btn-outline-danger w-100 rounded-pill fw-bold">TỪ CHỐI</button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>